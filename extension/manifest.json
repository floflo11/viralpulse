{
  "manifest_version": 3,
  "name": "ViralPulse — Save Viral Posts",
  "version": "1.1.0",
  "description": "Select and save any social media post to your ViralPulse library. Your AI agents use saved posts as references for creating viral content.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://api.aithatjustworks.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "activate-selector": {
      "suggested_key": { "default": "Ctrl+Shift+S", "mac": "Command+Shift+S" },
      "description": "Select a post to save"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
